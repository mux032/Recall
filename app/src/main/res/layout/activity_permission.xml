<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light"
    android:padding="32dp">

    <ImageView
        android:id="@+id/permission_icon"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_onboarding_privacy"
        android:contentDescription="Permission required"
        app:layout_constraintBottom_toTopOf="@id/title_text"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <TextView
        android:id="@+id/title_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Storage Permission Required"
        android:textAlignment="center"
        android:textAppearance="@style/TextAppearance.Recall.HeadlineMedium"
        android:textColor="@color/on_surface_light"
        app:layout_constraintBottom_toTopOf="@id/description_text"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/permission_icon" />

    <TextView
        android:id="@+id/description_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="We need access to your screenshots to make them searchable with AI. All processing happens on your device."
        android:textAlignment="center"
        android:textAppearance="@style/TextAppearance.Recall.BodyLarge"
        android:textColor="@color/on_surface_light"
        app:layout_constraintBottom_toTopOf="@id/grant_button"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/title_text" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/grant_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:text="Grant Permission"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/description_text" />

</androidx.constraintlayout.widget.ConstraintLayout>
