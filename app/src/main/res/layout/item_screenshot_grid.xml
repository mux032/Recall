<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="4dp"
    app:cardBackgroundColor="@color/surface_light"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/screenshot_image"
            android:layout_width="match_parent"
            android:layout_height="150dp"
            android:contentDescription="Screenshot"
            android:scaleType="centerCrop" />

        <TextView
            android:id="@+id/screenshot_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:maxLines="2"
            android:padding="8dp"
            android:textAppearance="@style/TextAppearance.Recall.Caption"
            android:textColor="@color/on_surface_light"
            android:visibility="gone" />

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
