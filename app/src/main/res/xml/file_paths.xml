<?xml version="1.0" encoding="utf-8"?>
<paths>
    <!--
        Grants FileProvider access to external storage files (e.g. screenshots in
        /storage/emulated/0/Pictures/Screenshots/) so they can be shared with other apps
        via a content:// URI without requiring READ_EXTERNAL_STORAGE on API 29+.
    -->
    <external-path
        name="external_files"
        path="." />
    <external-files-path
        name="external_app_files"
        path="." />
</paths>
