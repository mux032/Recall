<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/navigation_home">

    <fragment
        android:id="@+id/navigation_home"
        android:name="com.recall.app.presentation.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home">
        <action
            android:id="@+id/action_to_screenshotDetailFragment"
            app:destination="@id/screenshot_detail_fragment" />
    </fragment>

    <fragment
        android:id="@+id/navigation_categories"
        android:name="com.recall.app.presentation.categories.CategoriesFragment"
        android:label="Categories"
        tools:layout="@layout/fragment_categories" />

    <fragment
        android:id="@+id/navigation_settings"
        android:name="com.recall.app.presentation.settings.SettingsFragment"
        android:label="Settings"
        tools:layout="@layout/fragment_settings" />

    <fragment
        android:id="@+id/screenshot_detail_fragment"
        android:name="com.recall.app.presentation.detail.ScreenshotDetailFragment"
        android:label="Screenshot Detail"
        tools:layout="@layout/fragment_screenshot_detail">
        <argument
            android:name="screenshotId"
            app:argType="long"
            android:defaultValue="0L" />
    </fragment>

</navigation>
